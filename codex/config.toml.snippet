# ============================================================================
# Codex memory wiring — paste into ~/.codex/config.toml (user) or
# <project>/.codex/config.toml (project; loads only when the project is trusted).
# Replace REPLACE_WITH_ABS_PATH everywhere.
# ============================================================================

# --- MCP server (the in-session tool surface; same server as Claude Code) ----
[mcp_servers.agent-memory]
command = "python3"
args = ["REPLACE_WITH_ABS_PATH/agent-memory/core/mcp_server.py"]

[mcp_servers.agent-memory.env]
AGENT_MEMORY_ROOT = "REPLACE_WITH_ABS_PATH/agent-memory"
# The default store is the single install-root agent_memory.db. AGENT_MEMORY_DB
# remains available as an explicit migration/admin override, but normal task
# sessions should share this root DB.
# List tools in-session with /mcp once Codex restarts.

# --- Skill (portable) --------------------------------------------------------
# Put the shared skill at <project>/.agents/skills/agent-memory/SKILL.md
# (or ~/.codex/skills/agent-memory/SKILL.md for a user-wide skill).
# No config needed; Codex auto-discovers it. Restart Codex if it doesn't appear.

# --- Hooks (deterministic layer) --------------------------------------------
# Verified against developers.openai.com/codex/hooks: hook commands receive a
# JSON object on stdin (session_id, turn_id, and prompt for UserPromptSubmit),
# and registration uses nested table arrays per event — not a flat [[hooks]]
# list with event="..." and {{template}} substitution (an earlier, incorrect
# version of this snippet used that shape; don't reuse it).
#
# Each entry below invokes codex/hooks/*.py, which delegate into the shared
# claude-code/hooks/*.py logic. The hooks load code from this install root, so
# their default DB path matches AGENT_MEMORY_ROOT/agent_memory.db.

[[hooks.SessionStart]]
[[hooks.SessionStart.hooks]]
type = "command"
command = "python3 REPLACE_WITH_ABS_PATH/agent-memory/codex/hooks/on_session_start.py"

[[hooks.UserPromptSubmit]]
[[hooks.UserPromptSubmit.hooks]]
type = "command"
command = "python3 REPLACE_WITH_ABS_PATH/agent-memory/codex/hooks/on_prompt.py"

[[hooks.Stop]]
[[hooks.Stop.hooks]]
type = "command"
command = "python3 REPLACE_WITH_ABS_PATH/agent-memory/codex/hooks/on_stop.py"

# If Codex's hook events change shape again in a future release, re-verify
# against the Hooks doc before trusting this snippet. Until then, the MCP
# tools + skill + AGENTS.md still give you the full workflow on their own —
# without hooks you just lose the *deterministic* guarantee on the opening
# query and the seal, which then rely on the model following the protocol
# (advisory, like any prompt rule).
